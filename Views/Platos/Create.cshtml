@model RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Plato
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Nuevo Plato</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body class="admin-page">
    <nav class="admin-topbar">
        <div class="admin-brand">
            <span class="admin-brand-icon"><i class="bi bi-plus-circle"></i></span>
            <div>
                <small>Platos</small>
                <strong>Nuevo Plato</strong>
            </div>
        </div>
        <a class="admin-topbar-link" href="@Url.Action("Index")"><i class="bi bi-arrow-left"></i> Volver</a>
    </nav>

    <main class="admin-shell admin-shell-narrow">
        <section class="admin-panel">
            <div class="admin-panel-header">
                <div>
                    <p class="admin-eyebrow">Menu</p>
                    <h1>Registrar Plato</h1>
                </div>
            </div>

            @using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.Partial("_Form", Model)
                <div class="admin-form-actions">
                    <button class="btn admin-primary-btn" type="submit"><i class="bi bi-save"></i> Guardar</button>
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancelar</a>
                </div>
            }
        </section>
    </main>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    @if (ViewBag.SwalError != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'No se pudo guardar',
                text: '@HttpUtility.JavaScriptStringEncode(ViewBag.SwalError.ToString())'
            });
        </script>
    }
</body>
</html>
