@model RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Plato
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Editar Plato</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="header"><div class="header-title">Editar Plato</div></div>
    <div class="container">
        <div class="main-content">
            <h1>Editar Plato</h1>
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.IdPlato)
                @Html.HiddenFor(model => model.FechaRegistro)
                @Html.Partial("_Form", Model)
                <div class="button-container">
                    <button type="submit">Guardar</button>
                    <a class="app-button" href="@Url.Action("Index")">Volver</a>
                </div>
            }
        </div>
    </div>
</body>
</html>
