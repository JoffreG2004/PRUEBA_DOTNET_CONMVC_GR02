@model IEnumerable<RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Plato>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Platos</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body class="admin-page">
    <nav class="admin-topbar">
        <div class="admin-brand">
            <span class="admin-brand-icon"><i class="bi bi-basket2"></i></span>
            <div>
                <small>Administracion</small>
                <strong>Platos y Stock</strong>
            </div>
        </div>
        <a class="admin-topbar-link" href="@Url.Action("Dashboard", "Admin")">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </nav>

    <main class="admin-shell">
        <section class="admin-panel">
            <div class="admin-panel-header">
                <div>
                    <p class="admin-eyebrow">Inventario</p>
                    <h1>Platos</h1>
                </div>
                <a class="btn admin-primary-btn" href="@Url.Action("Create")">
                    <i class="bi bi-plus-lg"></i> Nuevo Plato
                </a>
            </div>

            <div class="admin-table-wrap">
                <table class="table admin-data-table align-middle">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Nombre</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var plato in Model)
                        {
                            <tr>
                                <td><span class="admin-type-pill">@(plato.TipoPlato != null ? plato.TipoPlato.Nombre : "")</span></td>
                                <td><strong>@plato.Nombre</strong></td>
                                <td>$ @plato.Precio</td>
                                <td>
                                    <span class="admin-stock-pill @(plato.Stock <= 5 ? "admin-stock-low" : "")">
                                        @plato.Stock disponibles
                                    </span>
                                </td>
                                <td>
                                    <span class="admin-status @(plato.Activo ? "admin-status-ok" : "admin-status-off")">
                                        @(plato.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td>
                                    <div class="admin-row-actions">
                                        <a class="btn btn-sm btn-outline-success" href="@Url.Action("Edit", new { id = plato.IdPlato })" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("AumentarStock", new { id = plato.IdPlato })" title="Aumentar stock">
                                            <i class="bi bi-box-seam"></i>
                                        </a>
                                        <a class="btn btn-sm btn-outline-danger js-confirm-link"
                                           href="@Url.Action("Delete", new { id = plato.IdPlato })"
                                           data-confirm-title="Desactivar plato"
                                           data-confirm-text="El plato @plato.Nombre ya no aparecera para comprar."
                                           data-confirm-button="Desactivar"
                                           title="Desactivar">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/Scripts/confirmaciones.js?v=4"></script>
    @if (TempData["SwalTitle"] != null)
    {
        <script>
            Swal.fire({
                icon: '@HttpUtility.JavaScriptStringEncode((TempData["SwalIcon"] ?? "success").ToString())',
                title: '@HttpUtility.JavaScriptStringEncode(TempData["SwalTitle"].ToString())',
                text: '@HttpUtility.JavaScriptStringEncode((TempData["SwalText"] ?? "").ToString())'
            });
        </script>
    }
</body>
</html>
