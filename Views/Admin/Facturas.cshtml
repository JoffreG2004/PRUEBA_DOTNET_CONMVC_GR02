@model IEnumerable<RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Pedido>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Facturas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body class="admin-page">
    <nav class="admin-topbar">
        <div class="admin-brand">
            <span class="admin-brand-icon"><i class="bi bi-receipt-cutoff"></i></span>
            <div>
                <small>Administracion</small>
                <strong>Facturas Emitidas</strong>
            </div>
        </div>
        <a class="admin-topbar-link" href="@Url.Action("Dashboard", "Admin")">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </nav>

    <main class="admin-shell">
        <section class="admin-panel">
            <div class="admin-panel-header">
                <div>
                    <p class="admin-eyebrow">Ventas</p>
                    <h1>Facturas</h1>
                </div>
            </div>

            <div class="admin-table-wrap">
                <table class="table admin-data-table align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Subtotal</th>
                            <th>IVA</th>
                            <th>Servicio</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th>Accion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pedido in Model)
                        {
                            <tr>
                                <td><strong>@pedido.IdPedido</strong></td>
                                <td>@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(pedido.Cliente != null ? pedido.Cliente.Nombres + " " + pedido.Cliente.Apellidos : "Consumidor final")</td>
                                <td>$ @pedido.Subtotal</td>
                                <td>$ @pedido.IvaValor</td>
                                <td>$ @pedido.ServicioValor</td>
                                <td><strong>$ @pedido.Total</strong></td>
                                <td><span class="admin-status admin-status-ok">@pedido.Estado</span></td>
                                <td>
                                    <a class="btn btn-sm btn-outline-success" href="@Url.Action("Factura", "Admin", new { id = pedido.IdPedido })">
                                        <i class="bi bi-eye"></i> Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
