@model RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Cliente

<div class="form-section admin-form-grid">
    <div class="form-group-vertical">
        @Html.LabelFor(model => model.Cedula)
        @Html.TextBoxFor(model => model.Cedula, new { @class = "form-input", maxlength = "10", data_filter = "numbers" })
        @Html.ValidationMessageFor(model => model.Cedula)
    </div>

    <div class="form-group-vertical">
        @Html.LabelFor(model => model.Nombres)
        @Html.TextBoxFor(model => model.Nombres, new { @class = "form-input", required = "required", maxlength = "100", data_filter = "letters" })
        @Html.ValidationMessageFor(model => model.Nombres)
    </div>

    <div class="form-group-vertical">
        @Html.LabelFor(model => model.Apellidos)
        @Html.TextBoxFor(model => model.Apellidos, new { @class = "form-input", required = "required", maxlength = "100", data_filter = "letters" })
        @Html.ValidationMessageFor(model => model.Apellidos)
    </div>

    <div class="form-group-vertical">
        @Html.LabelFor(model => model.Telefono)
        @Html.TextBoxFor(model => model.Telefono, new { @class = "form-input", maxlength = "10", data_filter = "numbers" })
        @Html.ValidationMessageFor(model => model.Telefono)
    </div>

    <div class="form-group-vertical">
        @Html.LabelFor(model => model.Email)
        @Html.TextBoxFor(model => model.Email, new { @class = "form-input", type = "email", maxlength = "120", data_filter = "email" })
        @Html.ValidationMessageFor(model => model.Email)
    </div>

    <div class="form-group-vertical">
        @Html.LabelFor(model => model.Direccion)
        @Html.TextBoxFor(model => model.Direccion, new { @class = "form-input", maxlength = "200" })
        @Html.ValidationMessageFor(model => model.Direccion)
    </div>

    <div class="form-group-vertical">
        <label>
            @Html.CheckBoxFor(model => model.Activo)
            Activo
        </label>
    </div>
</div>
