@model IEnumerable<RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Cliente>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Clientes</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body class="admin-page">
    <nav class="admin-topbar">
        <div class="admin-brand">
            <span class="admin-brand-icon"><i class="bi bi-person-vcard"></i></span>
            <div>
                <small>Administracion</small>
                <strong>Gestion de Clientes</strong>
            </div>
        </div>
        <a class="admin-topbar-link" href="@Url.Action("Dashboard", "Admin")">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </nav>

    <main class="admin-shell">
        <section class="admin-panel">
            <div class="admin-panel-header">
                <div>
                    <p class="admin-eyebrow">Clientes registrados</p>
                    <h1>Gestion de Clientes</h1>
                </div>
                <a class="btn admin-primary-btn" href="@Url.Action("Create")">
                    <i class="bi bi-plus-lg"></i> Nuevo Cliente
                </a>
            </div>

            <div class="admin-table-wrap">
                <table class="table admin-data-table align-middle">
                    <thead>
                        <tr>
                            <th>Cedula</th>
                            <th>Nombres</th>
                            <th>Apellidos</th>
                            <th>Telefono</th>
                            <th>Email</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cliente in Model)
                        {
                            <tr>
                                <td><strong>@cliente.Cedula</strong></td>
                                <td>@cliente.Nombres</td>
                                <td>@cliente.Apellidos</td>
                                <td>@cliente.Telefono</td>
                                <td>@cliente.Email</td>
                                <td>
                                    <span class="admin-status @(cliente.Activo ? "admin-status-ok" : "admin-status-off")">
                                        @(cliente.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td>
                                    <div class="admin-row-actions">
                                        <a class="btn btn-sm btn-outline-success" href="@Url.Action("Edit", new { id = cliente.IdCliente })" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = cliente.IdCliente })" title="Ver">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a class="btn btn-sm btn-outline-danger" href="@Url.Action("Delete", new { id = cliente.IdCliente })" title="Eliminar">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
