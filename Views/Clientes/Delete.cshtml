@model RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Cliente
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Eliminar Cliente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body class="admin-page">
    <nav class="admin-topbar">
        <div class="admin-brand">
            <span class="admin-brand-icon"><i class="bi bi-person-dash"></i></span>
            <div>
                <small>Clientes</small>
                <strong>Eliminar Cliente</strong>
            </div>
        </div>
        <a class="admin-topbar-link" href="@Url.Action("Index")">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </nav>

    <main class="admin-shell admin-shell-narrow">
        <section class="admin-panel">
            <div class="admin-delete-card">
                <i class="bi bi-exclamation-triangle"></i>
                <h1>Eliminar Cliente</h1>
                <p>Se marcara como inactivo a <strong>@Model.Nombres @Model.Apellidos</strong>.</p>

                @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "js-confirm-form", data_confirm_title = "Eliminar cliente", data_confirm_text = "El cliente quedara inactivo y no se borrara del historial.", data_confirm_button = "Eliminar" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="admin-form-actions">
                        <button class="btn btn-danger" type="submit"><i class="bi bi-trash3"></i> Eliminar</button>
                        <a class="btn btn-outline-secondary" href="@Url.Action("Index")">Cancelar</a>
                    </div>
                }
            </div>
        </section>
    </main>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/Scripts/confirmaciones.js?v=4"></script>
</body>
</html>
