@model RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Cliente
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Eliminar Cliente</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="header">
        <div class="header-title">Eliminar Cliente</div>
    </div>

    <div class="container">
        <div class="main-content">
            <h1>Eliminar Cliente</h1>
            <p>Se marcara como inactivo a @Model.Nombres @Model.Apellidos.</p>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <div class="button-container">
                    <button type="submit">Eliminar</button>
                    <a href="@Url.Action("Index")">Cancelar</a>
                </div>
            }
        </div>
    </div>
</body>
</html>
