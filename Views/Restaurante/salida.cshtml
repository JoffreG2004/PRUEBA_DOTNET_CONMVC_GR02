@model RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Pedido
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Resultado - Pedido</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>

    <div class="header">
        <div class="header-title">
            Restaurante Master Monster
        </div>

        <div class="header-logo">
            <img src="@Url.Content("~/Images/Monster.jpg")" alt="Logo" />
        </div>
    </div>

    <div class="container">
        <div class="main-content">

            <h1>Factura #@Model.IdPedido</h1>

            <h2>Datos del Cliente</h2>

            <table border="1">
                <tr>
                    <td>Cedula/RUC</td>
                    <td>@(Model.Cliente != null ? Model.Cliente.Cedula : "")</td>
                </tr>
                <tr>
                    <td>Nombres</td>
                    <td>@(Model.Cliente != null ? Model.Cliente.Nombres : "")</td>
                </tr>
                <tr>
                    <td>Apellidos</td>
                    <td>@(Model.Cliente != null ? Model.Cliente.Apellidos : "")</td>
                </tr>
                <tr>
                    <td>Telefono</td>
                    <td>@(Model.Cliente != null ? Model.Cliente.Telefono : "")</td>
                </tr>
                <tr>
                    <td>Email</td>
                    <td>@(Model.Cliente != null ? Model.Cliente.Email : "")</td>
                </tr>
                <tr>
                    <td>Direccion</td>
                    <td>@(Model.Cliente != null ? Model.Cliente.Direccion : "")</td>
                </tr>
            </table>

            <h2>Detalle del Pedido</h2>

            <table border="1" style="width:100%; text-align:center;">
                <tr>
                    <th>Nombre</th>
                    <th>Imagen</th>
                    <th>Cantidad</th>
                    <th>Precio Unitario</th>
                    <th>Subtotal</th>
                </tr>

                @if (Model.Detalles != null && Model.Detalles.Count > 0)
                {
                    foreach (var detalle in Model.Detalles)
                    {
                        <tr>
                            <td>@detalle.Plato.Nombre</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(detalle.Plato.Imagen))
                                {
                                    <img src="@Url.Content("~/Images/" + detalle.Plato.Imagen)" width="90" />
                                }
                            </td>
                            <td>@detalle.Cantidad</td>
                            <td>$ @detalle.PrecioUnitario</td>
                            <td>$ @detalle.Subtotal</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">No selecciono platos</td>
                    </tr>
                }
            </table>

            <table border="1" style="width:100%; text-align:right;">
                <tr><td>Subtotal</td><td>$ @Model.Subtotal</td></tr>
                <tr><td>IVA @Model.IvaPorcentaje%</td><td>$ @Model.IvaValor</td></tr>
                <tr><td>Servicio @Model.ServicioPorcentaje%</td><td>$ @Model.ServicioValor</td></tr>
                <tr><td><strong>Total</strong></td><td><strong>$ @Model.Total</strong></td></tr>
            </table>

            <div class="button-container">
                <a class="app-button" href="@Url.Action("Index", "Restaurante")">Realizar Otro Pedido</a>
            </div>

        </div>
    </div>

    <div class="footer">
        Master Monster © 2026
    </div>

</body>
</html>
