@model IEnumerable<RESTAURANT_CONMVC_DONET_BOLANOS_LUCIANA.Models.Plato>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Restaurante Master Monster</title>
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>

    <div class="header">
        <div class="header-title">
            Restaurante Master Monster
        </div>

        <div class="header-logo">
            <img src="@Url.Content("~/Images/Monster.jpg")" alt="Logo" />
        </div>
    </div>

    <div class="container">
        <div class="main-content">

            <h1>Realizar tu Pedido</h1>
            <p class="subtitle">Selecciona cualquier plato y la cantidad que deseas.</p>

            <div id="errores-validacion"></div>

            <form action="@Url.Action("Salida","Restaurante")" method="post" class="js-validate-client" data-confirm-title="Emitir factura" data-confirm-text="Se guardara el pedido y se descontara el stock seleccionado." data-confirm-button="Emitir factura">

                <div class="form-section">
                    <h2>Tus Datos</h2>
                    <div class="form-group-vertical">
                        <label>Tipo de cliente</label>
                        <label><input type="radio" name="tipoCliente" value="final" checked /> Consumidor final</label>
                        <label><input type="radio" name="tipoCliente" value="datos" /> Con datos</label>
                    </div>
                </div>

                <div class="form-section" id="datos-cliente" style="display:none;">
                    <h2>Datos para factura</h2>
                    <div class="form-group-vertical">
                        <label>Cedula</label>
                        <input type="text" name="cedula" placeholder="Ingresa tu cedula" class="form-input" maxlength="10" data-filter="numbers" />
                    </div>
                    <div class="form-group-vertical">
                        <label>Nombres</label>
                        <input type="text" name="nombres" placeholder="Ingresa tus nombres" class="form-input" data-filter="letters" />
                    </div>
                    <div class="form-group-vertical">
                        <label>Apellidos</label>
                        <input type="text" name="apellidos" placeholder="Ingresa tus apellidos" class="form-input" data-filter="letters" />
                    </div>
                    <div class="form-group-vertical">
                        <label>Telefono</label>
                        <input type="text" name="telefono" placeholder="Ejemplo: 0999999999" class="form-input" maxlength="10" data-filter="numbers" />
                    </div>
                    <div class="form-group-vertical">
                        <label>Email</label>
                        <input type="email" name="email" placeholder="usuario@dominio.com" class="form-input" data-filter="email" />
                    </div>
                    <div class="form-group-vertical">
                        <label>Direccion</label>
                        <input type="text" name="direccion" placeholder="Ingresa tu direccion" class="form-input" />
                    </div>
                </div>

                <table border="1" style="width:100%; text-align:center;">
                    <tr>
                        <th>Nombre</th>
                        <th>Imagen</th>
                        <th>Descripcion</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Cantidad</th>
                    </tr>

                    @foreach (var grupo in Model.GroupBy(p => p.TipoPlato != null ? p.TipoPlato.Nombre : "Otros"))
                    {
                        <tr class="category-title-row">
                            <td colspan="6"><strong>@grupo.Key</strong></td>
                        </tr>

                        foreach (var plato in grupo)
                        {
                            <tr>
                                <td>@plato.Nombre</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(plato.Imagen))
                                    {
                                        <img src="@Url.Content("~/Images/" + plato.Imagen)" width="90" alt="@plato.Nombre" />
                                    }
                                </td>
                                <td>@plato.Descripcion</td>
                                <td>$ @plato.Precio</td>
                                <td><strong>@plato.Stock</strong> disponibles</td>
                                <td>
                                    <div class="qty-control qty-inline" data-id="@plato.IdPlato" data-stock="@plato.Stock">
                                        <button type="button" class="qty-btn qty-minus">-</button>
                                        <input type="hidden" name="platoIds" value="@plato.IdPlato" class="plato-hidden" disabled />
                                        <input class="qty-input" type="text" name="cantidad_@plato.IdPlato" value="0" readonly />
                                        <button type="button" class="qty-btn qty-plus">+</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </table>

                <div class="order-summary-mini">
                    <span>Items seleccionados:</span>
                    <strong id="items-seleccionados">0</strong>
                </div>

                <div class="button-container">
                    <button type="submit"><i class="bi bi-receipt"></i> Confirmar Pedido</button>
                    <a class="app-button" href="@Url.Action("Index", "Home")">Volver</a>
                </div>

            </form>

        </div>
    </div>

    <div class="footer">
        Master Monster © 2026
    </div>

    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/Scripts/validaciones.js?v=4"></script>
    <script src="~/Scripts/confirmaciones.js?v=4"></script>
    @if (TempData["ErrorPedido"] != null)
    {
        <script>
            Swal.fire({
                title: 'Revisa el pedido',
                text: '@HttpUtility.JavaScriptStringEncode(TempData["ErrorPedido"].ToString())',
                icon: 'warning'
            });
        </script>
    }
    <script>
        document.querySelectorAll('input[name="tipoCliente"]').forEach(function (opcion) {
            opcion.addEventListener('change', function () {
                var conDatos = this.value === 'datos';
                document.getElementById('datos-cliente').style.display = conDatos ? 'block' : 'none';
                document.querySelectorAll('#datos-cliente input').forEach(function (input) {
                    input.required = conDatos;
                });
            });
        });

        function actualizarResumen() {
            var total = 0;
            document.querySelectorAll('.qty-input').forEach(function (input) {
                total += parseInt(input.value || '0', 10);
            });
            document.getElementById('items-seleccionados').textContent = total;
        }

        document.querySelectorAll('.qty-control').forEach(function (control) {
            var input = control.querySelector('.qty-input');
            var hidden = control.querySelector('.plato-hidden');
            var stock = parseInt(control.dataset.stock, 10);

            function setCantidad(valor) {
                var cantidad = Math.max(0, Math.min(stock, valor));
                input.value = cantidad;
                hidden.disabled = cantidad === 0;
                control.classList.toggle('qty-active', cantidad > 0);
                actualizarResumen();
            }

            control.querySelector('.qty-minus').addEventListener('click', function () {
                setCantidad(parseInt(input.value || '0', 10) - 1);
            });

            control.querySelector('.qty-plus').addEventListener('click', function () {
                setCantidad(parseInt(input.value || '0', 10) + 1);
            });
        });
    </script>
</body>
</html>
